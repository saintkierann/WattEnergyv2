# Copy this file to .env.local and fill in your key to enable meal scanning locally.
# (Manual macro entry works without a key.)

# Your Anthropic API key — kept server-side, never shipped to the browser.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the vision model. Default is claude-opus-4-8 (most capable).
# For lower cost per scan, use claude-sonnet-4-6 or claude-haiku-4-5.
# ANTHROPIC_MODEL=claude-sonnet-4-6
